generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  altText   String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Product {
  id            String          @id @default(cuid())
  name          String
  description   String
  price         Float
  discountPrice Float?
  rating        Float
  viewCount     Int             @default(0)
  images        ProductImage[]
  sizes         String
  isNew         Boolean         @default(false)
  tags          String
}
